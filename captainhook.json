{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "/^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\\([a-zA-Z0-9_-]+\\))?: .+$/",
                    "error": "The commit message MUST follow Conventional Commits format! (ex: 'feat: add scopes', 'fix: bug on filter')"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "composer validate --strict",
                "options": []
            },
            {
                "action": "composer audit --abandoned=ignore",
                "options": []
            },
            {
                "action": "composer run check:php -- {$STAGED_FILES|of-type:php}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["php"]
                    }
                ]
            },
            {
                "action": "composer run refactor:check -- {$STAGED_FILES|of-type:php}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["php"]
                    }
                ]
            },
            {
                "action": "composer run act:lint",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": [["yml", "yaml", "md", "json"]]
                    }
                ]
            }
        ]
    },
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": "composer run act:quality",
                "options": [],
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileChanged\\OfType",
                        "args": [["php", "json", "lock"]]
                    }
                ]
            },
            {
                "action": "composer run act:tests",
                "options": [],
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileChanged\\OfType",
                        "args": [["php", "json", "lock"]]
                    }
                ]
            }
        ]
    }
}

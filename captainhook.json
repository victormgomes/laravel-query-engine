{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "/^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\\([a-zA-Z0-9_-]+\\))?: .+$/",
                    "error": "The commit message MUST follow Conventional Commits format! (ex: 'feat: add scopes', 'fix: bug on filter')"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "composer validate --strict",
                "options": []
            },
            {
                "action": "composer audit --abandoned=ignore",
                "options": []
            },
            {
                "action": "composer run format:test -- {$STAGED_FILES|of-type:php}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["php"]
                    }
                ]
            },
            {
                "action": "composer run refactor:dry-run -- {$STAGED_FILES|of-type:php}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["php"]
                    }
                ]
            },
            {
                "action": "act -j actionlint -W .github/workflows/lint-infra.yml",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["yml"]
                    }
                ]
            },
            {
                "action": "act -j hadolint -W .github/workflows/lint-infra.yml",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\ThatIs",
                        "args": [["Dockerfile"]]
                    }
                ]
            },
            {
                "action": "act -j markdownlint -W .github/workflows/lint-infra.yml",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["md"]
                    }
                ]
            },
            {
                "action": "act -j jsonlint -W .github/workflows/lint-infra.yml",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["json"]
                    }
                ]
            }
        ]
    },
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": "act -j quality -W .github/workflows/code-quality.yml",
                "options": [],
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileChanged\\OfType",
                        "args": [["php", "json", "lock"]]
                    }
                ]
            },
            {
                "action": "act -j test -W .github/workflows/run-tests.yml",
                "options": [],
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileChanged\\OfType",
                        "args": [["php", "json", "lock"]]
                    }
                ]
            }
        ]
    }
}

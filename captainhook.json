{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "/^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\\([a-zA-Z0-9_-]+\\))?: .+$/",
                    "error": "The commit message MUST follow Conventional Commits format! (ex: 'feat: add scopes', 'fix: bug on filter')"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "composer validate --strict",
                "options": []
            },
            {
                "action": "composer run format:test -- {$STAGED_FILES|of-type:php}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["php"]
                    }
                ]
            },
            {
                "action": "composer run refactor:dry-run -- {$STAGED_FILES|of-type:php}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["php"]
                    }
                ]
            },
            {
                "action": "docker compose run --rm actionlint {$STAGED_FILES|of-type:yml}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["yml"]
                    }
                ]
            },
            {
                "action": "docker compose run --rm hadolint hadolint {$STAGED_FILES}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\ThatIs",
                        "args": [
                            ["Dockerfile"]
                        ]
                    }
                ]
            },
            {
                "action": "docker compose run --rm markdownlint {$STAGED_FILES|of-type:md}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["md"]
                    }
                ]
            },
            {
                "action": "docker compose run --rm jsonlint npx --yes prettier --check {$STAGED_FILES|of-type:json}",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["json"]
                    }
                ]
            }
        ]
    },
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": "composer run insights",
                "options": []
            },
            {
                "action": "composer run test",
                "options": []
            }
        ]
    }
}
